{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.scss",
      "**/*.jsx",
      "gulpfile.js",
      "package.json",
      "package-lock.json",
      "bower.json",
      "config.rb",
      ".imdone",
      "**/.github/**",
      "README.md",
      "LICENSE",
      "cache.manifest"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
